# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google OAuth (for "Sign in with Google")
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Add your site origin to "Authorized JavaScript origins".
# If unset, the Google button is hidden and only email/password login works.
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id

# DocuSeal Configuration (for digital signatures)
# Get your API key from: https://docuseal.com/settings/api
VITE_DOCUSEAL_API_KEY=your_docuseal_api_key_here

# Optional: Maptiler API Key (for enhanced map styles)
# Get a free key from: https://cloud.maptiler.com/
VITE_MAPTILER_API_KEY=your_maptiler_api_key_here

# Membership / bank details (do NOT hardcode in source — keep real values in .env)
# Previously stored in the now-gitignored bank_details.txt
VITE_BANK_ACCOUNT=your_account_number
VITE_BANK_IBAN=your_iban
VITE_BANK_NAME=your_bank_name
